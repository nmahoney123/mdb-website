# ── Runtime ─────────────────────────────────────────────────────
NODE_ENV=production        # "production" enables HSTS + fail-closed admin auth
PORT=3000                  # HTTP port the server listens on (production)

# ── Admin authentication ────────────────────────────────────────
# REQUIRED in production. If unset in production, admin login is DISABLED
# (fails closed) rather than accepting any default. Use a long, random value.
#   Generate one:  openssl rand -base64 24
ADMIN_PASSWORD=

# Session-signing secret (HMAC key for admin session cookies).
# REQUIRED in production for sessions that survive restarts. If unset, an
# ephemeral random secret is generated per process (secure, but every restart
# logs everyone out). Do NOT reuse ADMIN_PASSWORD here.
#   Generate one:  openssl rand -hex 32
APP_SECRET=

# ── Optional ────────────────────────────────────────────────────
APP_ID=                    # Application ID (optional metadata)
# SQLITE_PATH=./data/mdb.db  # Override the embedded SQLite database file path.
                           # The DB is file-based better-sqlite3 — no external
                           # database server is required.
# UPLOADS_DIR=./uploads    # Override where uploaded media is stored/served.
                           # In production point SQLITE_PATH and UPLOADS_DIR at a
                           # persistent disk (e.g. /var/data/…) so data survives deploys.
